        "y": {
          "$type": "spacing",
          "$value": "0.5rem"
        }
      },
      "border": {
        "radius": {
          "$type": "borderRadius",
          "$value": "{gdb.border.radius.default}"
        }
      },
      "focus": {
        "ring": {
          "width": {
            "$type": "borderWidth",
            "$value": "0"
          },
          "style": {
            "$type": "other",
            "$value": "none"
          },
          "color": {
            "$type": "color",
            "$value": "transparent"
          },
          "offset": {
            "$type": "borderWidth",
            "$value": "0"
          },
          "shadow": {
            "$type": "boxShadow",
            "$value": {
              "x": "0",
              "y": "0",
              "blur": "0",
              "spread": "0",
              "color": "rgba(0, 0, 0, 0)",
              "type": "dropShadow"
            }
          }
        }
      },
      "sm": {
        "font": {
          "size": {
