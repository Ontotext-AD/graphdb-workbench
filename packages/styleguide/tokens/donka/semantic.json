          }
        }
      },
      "transition": {
        "duration": {
          "$type": "other",
          "$value": "{transition.duration}"
        }
      }
    }
  },
  "content": {
    "border": {
      "radius": {
        "$type": "borderRadius",
        "$value": "{gdb.border.radius.default}"
      }
    }
  },
  "focus": {
    "ring": {
      "width": {
        "$type": "borderWidth",
        "$value": "1"
      },
      "color": {
        "$type": "color",
        "$value": "{primary.color}"
      },
      "offset": {
        "stroke": {
          "$value": {
            "color": "{app.card.background}",
            "width": "{focus.ring.offset}",
            "style": "solid"
          },
          "$type": "border"
        },
        "$type": "borderWidth",
        "$value": "2"
      },
      "shadow": {
        "$type": "boxShadow",
        "$value": {
          "x": "0",
          "y": "0",
          "blur": "0",
          "spread": "0",
          "color": "rgba(0, 0, 0, 0)",
          "type": "dropShadow"
        }
      },
      "stroke": {
        "$type": "border",
        "$value": {
          "color": "{focus.ring.color}",
          "width": "{focus.ring.offset} + {focus.ring.width}",
          "style": "{focus.ring.style}"
        }
      },
      "style": {
        "$type": "other",
        "$value": "solid"
      }
    }
  },
