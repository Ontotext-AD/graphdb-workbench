    "raised": {
      "shadow": {
        "$type": "boxShadow",
        "$value": [
          {
            "x": "0",
            "y": "3",
            "blur": "1",
            "spread": "-2",
            "color": "rgba(0, 0, 0, 0.2)",
            "type": "dropShadow"
