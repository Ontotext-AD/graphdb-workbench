    "figma": {
      "stroke": {
        "$type": "border",
        "$value": {
          "color": "{popover.border.color}",
          "width": "1",
          "style": "solid"
        }
      }
    }
  },
  "inputotp": {
    "input": {
      "width": {
        "$type": "sizing",
        "$value": "2.5rem"
      },
      "sm": {
        "width": {
          "$type": "sizing",
          "$value": "2rem"
        }
      },
      "lg": {
        "width": {
          "$type": "sizing",
          "$value": "3rem"
        }
      }
    },
    "gap": {
      "$type": "spacing",
      "$value": "0.5rem"
    }
  },
  "iftalabel": {
    "color": {
      "$type": "color",
      "$value": "{form.field.float.label.color}"
    },
    "focus": {
      "color": {
        "$type": "color",
        "$value": "{form.field.float.label.focus.color}"
      }
    },
    "invalid": {
      "color": {
        "$type": "color",
        "$value": "{form.field.float.label.invalid.color}"
      }
    },
    "transition": {
      "duration": {
        "$type": "other",
        "$value": "0.2s"
      }
    },
    "position": {
      "x": {
        "$type": "spacing",
        "$value": "{form.field.padding.x}"
      }
    },
    "top": {
      "$type": "spacing",
      "$value": "{form.field.padding.y}"
    },
    "font": {
      "size": {
        "$type": "fontSizes",
        "$value": "0.75rem"
      },
      "weight": {
        "$type": "fontWeights",
        "$value": "400"
      }
    },
    "input": {
      "padding": {
        "top": {
          "$type": "spacing",
          "$value": "1.5rem"
        },
        "bottom": {
          "$type": "spacing",
          "$value": "{form.field.padding.y}"
        }
      }
    },
    "figma": {
      "line": {
        "height": {
          "$type": "lineHeights",
          "$value": "{iftalabel.font.size}"
        }
      }
    }
  }
}
