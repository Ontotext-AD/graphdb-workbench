    "figma": {
      "stroke": {
        "$type": "border",
        "$value": {
          "color": "{inputtext.border.color}",
          "width": "1",
          "style": "solid"
        }
      },
      "hover": {
        "stroke": {
          "$type": "border",
          "$value": {
            "color": "{inputtext.hover.border.color}",
            "width": "1",
            "style": "solid"
