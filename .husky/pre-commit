#!/usr/bin/env sh
echo "Running pre-commit hook..."

# Load Husky helpers if available
HUSKY_SH="$(dirname "$0")/_/husky.sh"
if [ -s "$HUSKY_SH" ]; then
  . "$HUSKY_SH"
else
  echo "Warning: Husky helpers not found, continuing anyway..."
fi

# Ensure Node is installed
if ! command -v node >/dev/null 2>&1; then
  echo "Node.js not found. Skipping lint-staged."
  exit 0
fi

# Ensure npm is installed
if ! command -v npm >/dev/null 2>&1; then
  echo "npm not found. Skipping lint-staged."
  exit 0
fi

# Load nvm if available
export NVM_DIR="$HOME/.nvm"
if [ -s "$NVM_DIR/nvm.sh" ]; then
  . "$NVM_DIR/nvm.sh"
fi

# Ensure lint-staged is available
if ! command -v npx >/dev/null 2>&1; then
  echo "npx not found. Skipping lint-staged."
  exit 0
fi

echo "Running lint-staged..."
npx lint-staged --debug
LINT_EXIT_CODE=$?

if [ $LINT_EXIT_CODE -ne 0 ]; then
  echo "Linting failed, commit aborted."
  exit 1
fi

echo "Pre-commit hook finished successfully."
exit 0
